            // Bodování
            Label lblRat = new Label { Text = "Ohodnotit (1-10):", Left = 440, Top = 28, ForeColor = Color.White, Width = 110 };
            numRating = new NumericUpDown { Left = 550, Top = 25, Minimum = 1, Maximum = 10, Value = 10, Width = 50, Font = new Font("Segoe UI", 10) };
            Button btnUlozit = new Button { Text = "Uložit body", Left = 610, Top = 23, Width = 110, Height = 28, BackColor = Color.LightGray };
            btnUlozit.Click += UlozitBodovani_Click;

            // Náhodný tip
