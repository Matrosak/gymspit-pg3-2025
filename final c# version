            btnNahoda.Click += (s, e) => {
                if (databaze.Count > 0)
                {
                    var nahodnaHospoda = databaze[new Random().Next(databaze.Count)];
                    string ratText = ratingy.ContainsKey(nahodnaHospoda.Id) ? Math.Round(ratingy[nahodnaHospoda.Id].Average(), 1).ToString() + "/10" : "Zatím nehodnoceno";

                    MessageBox.Show(
                        $"Dnes vyzkoušejte podnik:\n\n" +
