            this.Controls.Add(lblStatus);

            FiltrovatData();
        }

        // Pomocná metoda pro spolehlivé odstranění diakritiky při vyhledávání
        private string OdstranDiakritiku(string text)
        {
            if (string.IsNullOrEmpty(text)) return "";
            string normalizedString = text.Normalize(NormalizationForm.FormD);
            StringBuilder stringBuilder = new StringBuilder();

            foreach (char c in normalizedString)
            {
                UnicodeCategory unicodeCategory = CharUnicodeInfo.GetUnicodeCategory(c);
                if (unicodeCategory != UnicodeCategory.NonSpacingMark)
                {
                    stringBuilder.Append(c);
                }
            }
            return stringBuilder.ToString().Normalize(NormalizationForm.FormC).ToLower();
        }

        private void FiltrovatData()
        {
            // Vyhledávací fráze očištěná o diakritiku a mezery
            string filtr = OdstranDiakritiku(txtHledat.Text);
            
            var vysledek = databaze
                .Where(h => OdstranDiakritiku(h.Nazev).Contains(filtr) || 
                            OdstranDiakritiku(h.Ctvrt).Contains(filtr) || 
                            OdstranDiakritiku(h.Pivo).Contains(filtr))
                .Select(h => new UIHospoda {
                    Id = h.Id,
                    Název_Podniku = h.Nazev,
                    Čtvrť = h.Ctvrt,
                    Piva_Na_Čepu = h.Pivo,
                    Hodnocení = ratingy.ContainsKey(h.Id) ? Math.Round(ratingy[h.Id].Average(), 1).ToString() + " / 10" : "Zatím nehodnoceno",
                    Hlasovalo = ratingy.ContainsKey(h.Id) ? ratingy[h.Id].Count : 0,
                    RawPrumer = ratingy.ContainsKey(h.Id) ? ratingy[h.Id].Average() : 0.0
                })
                .OrderByDescending(h => h.RawPrumer)
                .ThenBy(h => h.Název_Podniku)
                .ToList();

            // Bezpečné přiřazení dat přes typovanou strukturu
            grid.DataSource = vysledek;

            // Skrytí pomocných sloupců (až když data v tabulce reálně existují)
            if (grid.Columns["Id"] != null) grid.Columns["Id"].Visible = false;
            if (grid.Columns["RawPrumer"] != null) grid.Columns["RawPrumer"].Visible = false;

            lblStatus.Text = $" Zobrazeno {vysledek.Count} hospod. Zkus napsat např.: zizkov, prosek, praha 1, ladví, brebnov...";
        }

        private void UlozitBodovani_Click(object sender, EventArgs e)
        {
            if (grid.SelectedRows.Count > 0)
            {
                // Bezpečné vytáhnutí ID přes silně typovaný objekt UIHospoda
                var vybranyRadek = (UIHospoda)grid.SelectedRows[0].DataBoundItem;
                int id = vybranyRadek.Id;
                int novaZnamka = (int)numRating.Value;

                if (!ratingy.ContainsKey(id)) ratingy[id] = new List<int>();
                ratingy[id].Add(novaZnamka);

                try
                {
                    File.AppendAllText(ratingFile, $"{id};{novaZnamka}{Environment.NewLine}");
                    FiltrovatData();
                    MessageBox.Show($"Hodnocení {novaZnamka}/10 uloženo!", "Hotovo");
                }
                catch (Exception ex)
                {
                    MessageBox.Show("Chyba při ukládání: " + ex.Message);
                }
            }
            else
            {
                MessageBox.Show("Nejprve kliknutím v tabulce vyberte hospodu.");
            }
        }

        private void NacistUlozeneRatingy()
        {
            if (File.Exists(ratingFile))
            {
                var radky = File.ReadAllLines(ratingFile);
                foreach (var radek in radky)
                {
                    var casti = radek.Split(';');
                    if (casti.Length == 2 && int.TryParse(casti[0], out int id) && int.TryParse(casti[1], out int val))
                    {
                        if (!ratingy.ContainsKey(id)) ratingy[id] = new List<int>();
                        ratingy[id].Add(val);
                    }
                }
            }
        }
    }

